# Скопируй в .env и заполни значения. Не коммить .env.

# --- БД ---
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=5432

# --- Buddy alerts (ежедневный digest на хосте, scripts/run_buddy_daily_digest.py) ---
BUDDY_ALERT_TZ=Europe/Moscow

# --- «Завтрак» / Света (OpenRouter — основной провайдер) ---
OPENROUTER_API_KEY=
# OPENROUTER_API_KEY_2=
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_FALLBACK_MODEL=google/gemma-4-26b-a4b-it:free,openrouter/free
# OPENROUTER_HTTP_REFERER=https://islanddream.ru
# OPENROUTER_APP_TITLE=OSTROV Breakfast

# Fallback (опционально, если OpenRouter недоступен)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=
# BREAKFAST_AI_USE_HF=0

# --- Прочее ---
