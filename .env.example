# Скопируй в .env и заполни значения. Не коммить .env.

# --- БД ---
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=
DB_PORT=5432

# --- «Завтрак» / Света (OpenRouter — основной провайдер) ---
OPENROUTER_API_KEY=
# OPENROUTER_API_KEY_2=
OPENROUTER_MODEL=google/gemini-flash-1.5
# OPENROUTER_HTTP_REFERER=https://islanddream.ru
# OPENROUTER_APP_TITLE=OSTROV Breakfast

# Fallback (опционально, если OpenRouter недоступен)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# OPENAI_API_KEY=
# BREAKFAST_AI_USE_HF=0

# --- Прочее ---
# BREAKFAST_SAVE_TO_DB=0
# BOT_API_KEY=
